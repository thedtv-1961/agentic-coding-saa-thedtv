#----------------------------------------------------------
# Supabase Environment Variables (server-side)
#----------------------------------------------------------
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
SUPABASE_SECRET_KEY=your_supabase_secret_key

#----------------------------------------------------------
# Supabase Environment Variables (browser/client)
#   Bắt buộc tiền tố NEXT_PUBLIC_ thì browser mới đọc được.
#   Dùng bởi utils/supabase/client.ts (vd: upload ảnh Kudos).
#   LƯU Ý: được nhúng vào bundle lúc BUILD — khi build để deploy
#   production phải đặt giá trị URL/key của Supabase production.
#----------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key

#----------------------------------------------------------
# Google OAuth (optional, for Supabase Auth)
#   Get these from https://console.cloud.google.com/apis/credentials
#----------------------------------------------------------
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

#----------------------------------------------------------
# Supabase Seeds (dev only)
#----------------------------------------------------------
SUPABASE_EXTRA_SEEDS=./supabase/seeds/dev/*.sql

#----------------------------------------------------------
# Supabase Service Role (server-side only — never expose to client)
#----------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
